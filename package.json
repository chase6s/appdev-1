{
  "name": "appdev-1",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack SaaS monorepo",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "dev": "pnpm -r --parallel run dev",
    "lint": "eslint 'apps/*/src/**/*.{ts,tsx}'",
    "format": "prettier --check 'apps/*/src/**/*.{ts,tsx,json,md}'",
    "format:fix": "prettier --write 'apps/*/src/**/*.{ts,tsx,json,md}'",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "ci": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "typescript": "~5.7.0",
    "eslint": "^9.18.0",
    "@eslint/js": "^9.18.0",
    "typescript-eslint": "^8.20.0",
    "prettier": "^3.4.0"
  }
}